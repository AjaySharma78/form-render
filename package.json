{
  "name": "json-form-render",
  "version": "0.1.0",
  "description": "Headless, JSON-driven React form engine. Declarative schema compiled to Zod + React Hook Form, rendered through an injectable component adapter (shadcn-ready).",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AjaySharma78/form-render.git"
  },
  "homepage": "https://github.com/AjaySharma78/form-render#readme",
  "bugs": "https://github.com/AjaySharma78/form-render/issues",
  "bin": {
    "form-render": "bin/form-render.mjs"
  },
  "files": [
    "dist",
    "templates",
    "bin",
    "styles.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters/html": {
      "types": "./dist/adapters/html.d.ts",
      "import": "./dist/adapters/html.js",
      "require": "./dist/adapters/html.cjs"
    },
    "./styles.css": "./styles.css"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@hookform/resolvers": ">=3",
    "react": ">=18",
    "react-dom": ">=18",
    "react-hook-form": ">=7.45",
    "zod": ">=3.22"
  },
  "devDependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsdom": "^25.0.1",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "rimraf": "^6.0.1",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9",
    "zod": "^3.23.8"
  },
  "keywords": [
    "react",
    "form",
    "json-schema",
    "form-builder",
    "react-hook-form",
    "zod",
    "shadcn",
    "headless"
  ]
}
